# OpenMDIM environment variables — NAMES ONLY. Never commit real values.
# Copy to .env (gitignored) and fill in. Local-dev connection-string examples live
# in the "How to run" section of README.md, not here.

# === Database (Prisma) ===
DATABASE_URL=
DIRECT_URL=

# === Supabase (managed Postgres for deployed environments) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Redis (BullMQ) ===
REDIS_URL=

# === Object storage (MinIO dev / S3-compatible prod) ===
MINIO_ENDPOINT=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=

# === API ===
API_PORT=

# === Web (only VITE_* vars are exposed to the browser) ===
VITE_API_URL=
