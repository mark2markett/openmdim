# OpenMDIM environment variables — NAMES ONLY. Never commit real values.
# Copy to .env and fill in. .env is gitignored.

# === Database (Prisma) ===
# Pooled connection used by the app at runtime (Supabase pooler / PgBouncer in prod).
# Local dev example (matches docker-compose host port 5433): postgresql://openmdim:openmdim@localhost:5433/openmdim?schema=public
DATABASE_URL=
# Direct (non-pooled) connection used by Prisma Migrate / introspection.
# Local dev example: postgresql://openmdim:openmdim@localhost:5433/openmdim?schema=public
DIRECT_URL=

# === Supabase (managed Postgres for deployed environments) ===
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Redis (BullMQ) ===
# Local dev example (matches docker-compose host port 6380): redis://localhost:6380
REDIS_URL=

# === Object storage (MinIO in dev, S3-compatible in prod) ===
# Local dev example (matches docker-compose host port 9100): http://localhost:9100
MINIO_ENDPOINT=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET=

# === API ===
API_PORT=3000

# === Web (Vite — only VITE_* vars are exposed to the browser) ===
VITE_API_URL=
